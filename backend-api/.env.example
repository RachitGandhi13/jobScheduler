# === Database (Neon) ===================================================
# Use Neon's *direct* (non-pooled) connection string, not the "-pooler" one.
# backend-api is a long-running Node process that manages its own connection
# pool (via the `postgres` driver) and issues prepared statements; routing
# that through Neon's PgBouncer pooler in transaction mode breaks prepared
# statements because a statement prepared on one PgBouncer-assigned backend
# connection may not exist on the next. Neon's dashboard gives you both --
# copy the one *without* "-pooler" in the hostname. Append ?sslmode=require
# if it isn't already present.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_scheduler

# === Server ==============================================================
# Render injects its own PORT at runtime; this default is only used locally.
PORT=4000

# === Auth =================================================================
# Signing/verification secret for issued JWTs ({ userId, organizationId }
# payload). Generate a real one with: openssl rand -base64 48
# Rotating this invalidates every previously issued token.
JWT_SECRET=change-me

# Dev-only escape hatch: authenticates requests via x-mock-user-id /
# x-mock-organization-id headers instead of a signed JWT, since there's no
# login endpoint yet. Leave this var OUT of Render's environment entirely for
# every deployed environment -- do not set it to any value, including false.
MOCK_AUTH=true

# === Reliability tuning ===================================================
# How long a worker can go without sending a heartbeat before the
# zombie-cleanup sweep marks it offline and requeues whatever it was holding.
WORKER_HEARTBEAT_TIMEOUT_MS=15000
# How often that sweep runs.
ZOMBIE_CLEANUP_INTERVAL_MS=10000
