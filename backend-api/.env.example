# === Database (Neon) ===================================================
# Either Neon connection string works, direct or pooled ("-pooler"). Pooled
# connections route through PgBouncer in transaction mode, which normally
# breaks prepared statements (a statement prepared on one PgBouncer-assigned
# backend connection may not exist on the next) -- packages/db's client sets
# `prepare: false` specifically so that's not a problem here, verified
# against both a multi-insert signup transaction and worker-service's
# FOR UPDATE SKIP LOCKED claim transaction. Append ?sslmode=require if Neon's
# string doesn't already include it.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_scheduler

# === Server ==============================================================
# Render injects its own PORT at runtime; this default is only used locally.
PORT=4000

# Comma-separated list of origins allowed to call this API from a browser
# (the dashboard's fetch() calls). Auth here is Bearer-token, never cookies,
# so a wide-open CORS policy wouldn't itself leak credentials cross-origin --
# but pin this to your real frontend URL(s) anyway. Include your Vercel
# production URL, e.g.:
# CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# === Auth =================================================================
# Signing/verification secret for issued JWTs ({ userId, organizationId }
# payload). Generate a real one with: openssl rand -base64 48
# Rotating this invalidates every previously issued token.
JWT_SECRET=change-me

# Dev-only escape hatch: authenticates requests via x-mock-user-id /
# x-mock-organization-id headers instead of a signed JWT -- useful for
# scripting/testing without going through POST /api/auth/signup. Leave this
# var OUT of Render's environment entirely for every deployed environment --
# do not set it to any value, including false.
MOCK_AUTH=true

# === Reliability tuning ===================================================
# How long a worker can go without sending a heartbeat before the
# zombie-cleanup sweep marks it offline and requeues whatever it was holding.
WORKER_HEARTBEAT_TIMEOUT_MS=15000
# How often that sweep runs.
ZOMBIE_CLEANUP_INTERVAL_MS=10000

# === Bonus features =======================================================
# How often the /ws WebSocket endpoint pushes a fresh workers+metrics
# snapshot to each connected client. See README's "WebSocket live updates".
WS_PUSH_INTERVAL_MS=3000
