# Base URL of the deployed backend-api, including the /api prefix.
#
# Local dev:   http://localhost:4000/api
# Production:  set this as a Vercel Project environment variable pointing at
#              your Render backend-api service's public URL, e.g.
#              https://scheduler-backend.onrender.com/api
#
# Vite inlines this at build time -- changing it on Vercel requires a redeploy,
# not just a restart.
VITE_API_BASE_URL=http://localhost:4000/api
