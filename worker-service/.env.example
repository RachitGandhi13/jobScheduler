# === Database (Neon) ===================================================
# Same schema as backend-api, same connection string: either direct or pooled
# ("-pooler") works. worker-service holds multi-statement transactions
# (claim, then later the completion/retry/DLQ transaction) which would
# normally be unsafe under PgBouncer's transaction pooling mode --
# packages/db's client sets `prepare: false` so this is handled. Append
# ?sslmode=require if Neon's string doesn't include it.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_scheduler

# === Polling / concurrency tuning ========================================
# Only used by the continuous loop (`npm start` / src/index.ts), not the
# one-shot cron entrypoint below. How often this worker polls each active
# queue for due jobs.
POLL_INTERVAL_MS=1000
# How often this worker updates workers.last_heartbeat_at (must stay well
# under backend-api's WORKER_HEARTBEAT_TIMEOUT_MS, or it'll flap offline).
# Used by both entrypoints.
HEARTBEAT_INTERVAL_MS=5000
# Max jobs claimed from a single queue in one sweep (upper bound on the LIMIT
# in claim.ts's SELECT ... FOR UPDATE SKIP LOCKED query). Used by both.
MAX_CLAIM_PER_QUEUE=5

# Render background workers (paid tier) scale by running multiple instances
# of this same service -- each one registers as its own row in `workers` and
# claims independently; no extra config needed for horizontal scale-out.

# === One-shot / Cron Job mode (`npm run start:once` / src/runOnce.ts) ====
# Free alternative to Render's paid Background Worker: run as a Render Cron
# Job instead. Registers, sweeps every active queue repeatedly until a pass
# claims nothing, drains, marks itself offline, exits -- instead of polling
# forever. Wall-clock budget for one invocation, so a busy run never spills
# past the next scheduled tick (tune down if your cron schedule fires more
# often than every ~45s+MAX_RUN_MS, or up if it fires less often and you want
# a bigger backlog drained per run).
MAX_RUN_MS=45000
