# === Database (Neon) ===================================================
# Same schema as backend-api, same connection-string guidance: use Neon's
# *direct* (non-pooled) connection string, not "-pooler". worker-service
# holds connections across multi-statement transactions (claim, then later
# the completion/retry/DLQ transaction) and relies on prepared statements
# from the `postgres` driver -- both are unsafe under PgBouncer's transaction
# pooling mode. Append ?sslmode=require if Neon's string doesn't include it.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_scheduler

# === Polling / concurrency tuning ========================================
# How often this worker polls each active queue for due jobs.
POLL_INTERVAL_MS=1000
# How often this worker updates workers.last_heartbeat_at (must stay well
# under backend-api's WORKER_HEARTBEAT_TIMEOUT_MS, or it'll flap offline).
HEARTBEAT_INTERVAL_MS=5000
# Max jobs claimed from a single queue in one poll tick (upper bound on the
# LIMIT in claim.ts's SELECT ... FOR UPDATE SKIP LOCKED query).
MAX_CLAIM_PER_QUEUE=5

# Render background workers scale by running multiple instances of this same
# service -- each one registers as its own row in `workers` and claims
# independently; no extra config needed for horizontal scale-out.
