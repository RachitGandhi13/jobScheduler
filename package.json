{
  "name": "distributed-job-scheduler",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend-api",
    "worker-service",
    "frontend-dashboard",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w backend-api",
    "dev:worker": "npm run dev -w worker-service",
